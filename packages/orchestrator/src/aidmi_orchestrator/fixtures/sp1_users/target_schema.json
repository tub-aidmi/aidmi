{
  "tables": [
    {
      "name": "users",
      "description": "Normalized user records derived from raw contacts.",
      "primary_key": ["user_id"],
      "columns": [
        {"name": "user_id", "sql_type": "integer", "nullable": false, "description": "stable identifier from source"},
        {"name": "firstname", "sql_type": "text", "nullable": true, "description": "Title-cased given name"},
        {"name": "lastname", "sql_type": "text", "nullable": true, "description": "Title-cased family name"},
        {"name": "email_address", "sql_type": "text", "nullable": true, "description": "Trimmed and lowercased"},
        {"name": "phone_number", "sql_type": "text", "nullable": true},
        {"name": "status_enum", "sql_type": "text", "nullable": false, "enum_values": ["active", "inactive", "archived", "unknown"]},
        {"name": "created_at", "sql_type": "timestamp", "nullable": true}
      ]
    }
  ]
}
