2026-07-04 16:24:43 [ensemble_vote] candidates_judged (target_table='Opportunity', chosen_index=0, justification='Candidate 0 provides a more comprehensive mapping for the NOT NULL `StageName` enum, which is crucial for data correctness. Its amount parsing, while slightly verbose, clearly addresses the specified transformation rules for locale-specific separators and currency symbols.', candidate_sqls=['\n{{ config(materialized=\'table\') }}\n\nWITH source_opportunity AS (\n    SELECT\n        id,\n        name,\n        stagename,\n        closedate,\n        amount,\n        currencyisocode,\n        accountid\n    FROM {{ source(\'fixture_messy_data_v2_src\', \'opportunity\') }}\n)\nSELECT\n    id AS "Id",\n    COALESCE(name, \'Untitled Opportunity\') AS "Name",\n    CASE\n        WHEN LOWER(TRIM(stagename)) IN (\'closed won\', \'won\', \'gewonnen\', \'abgeschlossen (gewonnen)\') THEN \'Closed Won\'\n        WHEN LOWER(TRIM(stagename)) IN (\'closed lost\', \'lost\', \'verloren\', \'abgeschlossen (verloren)\') THEN \'Closed Lost\'\n        WHEN LOWER(TRIM(stagename)) IN (\'qualification\', \'qualifikation\', \'quali\') THEN \'Qualification\'\n        WHEN LOWER(TRIM(stagename)) IN (\'prospecting\', \'prospect\', \'in kontakt\') THEN \'Prospecting\'\n        WHEN LOWER(TRIM(stagename)) IN (\'in prüfung\') THEN \'Negotiation/Review\' -- Best guess based on translation\n        WHEN LOWER(TRIM(stagename)) IN (\'needs analysis\') THEN \'Needs Analysis\'\n        WHEN LOWER(TRIM(stagename)) IN (\'value proposition\') THEN \'Value Proposition\'\n        WHEN LOWER(TRIM(stagename)) IN (\'id. decision makers\', \'identification of decision makers\') THEN \'Id. Decision Makers\'\n        WHEN LOWER(TRIM(stagename)) IN (\'perception analysis\') THEN \'Perception Analysis\'\n        WHEN LOWER(TRIM(stagename)) IN (\'proposal/price quote\', \'proposal\', \'price quote\') THEN \'Proposal/Price Quote\'\n        WHEN LOWER(TRIM(stagename)) IN (\'negotiation/review\', \'negotiation\', \'review\') THEN \'Negotiation/Review\'\n        ELSE \'Prospecting\' -- Default for unknown stages or NULL\n    END AS "StageName",\n    COALESCE(\n        TO_CHAR(TO_DATE(closedate, \'YYYYMMDD\'), \'YYYY-MM-DD\'),\n        TO_CHAR(TO_DATE(closedate, \'MM/DD/YYYY\'), \'YYYY-MM-DD\'),\n        TO_CHAR(TO_DATE(closedate, \'YYYY-MM-DD\'), \'YYYY-MM-DD\'),\n        TO_CHAR(TO_DATE(closedate, \'DD.MM.YYYY\'), \'YYYY-MM-DD\'),\n        \'2999-12-31\' -- Default date if all parsing fails, ensuring NOT NULL\n    ) AS "CloseDate",\n    CASE\n        WHEN amount IS NULL THEN NULL\n        ELSE\n            CASE\n                WHEN REGEXP_REPLACE(\n                        REPLACE(\n                            REPLACE(LOWER(TRIM(amount)), \'eur \', \'\'),\n                            \'.\', \'\'\n                        ),\n                        \',\', \'.\'\n                    ) ~ \'^[+-]?\\d+(\\.\\d+)?$\'\n                THEN\n                    CAST(\n                        REGEXP_REPLACE(\n                            REPLACE(\n                                REPLACE(LOWER(TRIM(amount)), \'eur \', \'\'),\n                                \'.\', \'\'\n                            ),\n                            \',\', \'.\'\n                        ) AS DOUBLE PRECISION\n                    )\n                ELSE NULL\n            END\n    END AS "Amount",\n    currencyisocode AS "CurrencyIsoCode",\n    accountid AS "AccountId",\n    id AS "Legacy_Opportunity_ID__c",\n    NULL AS "CreatedDate",\n    NULL AS "LastModifiedDate",\n    0 AS "IsDeleted"\nFROM source_opportunity\n', '\n{{ config(materialized=\'table\') }}\n\nSELECT\n    s.id AS "Id",\n    COALESCE(s.name, \'Unknown Opportunity\') AS "Name",\n    CASE\n        WHEN LOWER(s.stagename) IN (\'closed won\', \'closedwon\') THEN \'Closed Won\'\n        WHEN LOWER(s.stagename) IN (\'closed lost\', \'lost\') THEN \'Closed Lost\'\n        WHEN LOWER(s.stagename) IN (\'prospecting\', \'prospect\') THEN \'Prospecting\'\n        WHEN LOWER(s.stagename) = \'in prüfung\' THEN \'Negotiation/Review\'\n        -- Default to Prospecting if not explicitly mapped or NULL\n        ELSE \'Prospecting\'\n    END AS "StageName",\n    COALESCE(\n        (CASE\n            WHEN s.closedate ~ \'^\\d{8}$\' THEN TO_DATE(s.closedate, \'YYYYMMDD\') -- e.g., 20260401\n            WHEN s.closedate ~ \'^\\d{4}-\\d{2}-\\d{2}$\' THEN TO_DATE(s.closedate, \'YYYY-MM-DD\') -- e.g., 2027-01-15\n            WHEN s.closedate ~ \'^\\d{1,2}/\\d{1,2}/\\d{4}$\' THEN TO_DATE(s.closedate, \'MM/DD/YYYY\') -- e.g., 2/6/2025\n            WHEN s.closedate ~ \'^\\d{1,2}\\.\\d{1,2}\\.\\d{4}$\' THEN TO_DATE(s.closedate, \'DD.MM.YYYY\') -- e.g., 16.11.2026\n            ELSE NULL\n        END)::TEXT,\n        \'1900-01-01\' -- Default for unparseable or NULL dates\n    ) AS "CloseDate",\n    CAST(\n        CASE\n            WHEN s.amount IS NULL OR TRIM(s.amount) = \'\' THEN NULL\n            ELSE\n                -- Step 1: Clean the string, removing all non-essential characters\n                -- Keep digits, comma, dot, and negative sign\n                (SELECT\n                    CASE\n                        -- European format: contains comma, and either no dot or dot appears before comma\n                        -- e.g., \'1.234,56\' -> dot is thousands, comma is decimal\n                        WHEN cleaned_amount_raw LIKE \'%.%,%\' AND POSITION(\',\', cleaned_amount_raw) > POSITION(\'.\', cleaned_amount_raw)\n                        THEN REPLACE(REPLACE(cleaned_amount_raw, \'.\', \'\'), \',\', \'.\') -- Remove dots, then change comma to dot\n                        -- Case where only comma is the decimal separator (e.g. 123,45)\n                        WHEN cleaned_amount_raw LIKE \'%,%\'\n                        THEN REPLACE(cleaned_amount_raw, \',\', \'.\')\n                        -- Otherwise (standard format or no decimal), use as is\n                        ELSE cleaned_amount_raw\n                    END\n                FROM (\n                    SELECT REGEXP_REPLACE(LOWER(TRIM(s.amount)), \'[^0-9.,-]+\', \'\', \'g\') AS cleaned_amount_raw\n                ) AS _subquery\n                )\n        END AS DOUBLE PRECISION\n    ) AS "Amount",\n    CASE LOWER(s.currencyisocode)\n        WHEN \'euro\' THEN \'EUR\'\n        WHEN \'dollar\' THEN \'USD\'\n        WHEN \'chf\' THEN \'CHF\'\n        WHEN \'usd\' THEN \'USD\'\n        WHEN \'gbp\' THEN \'GBP\'\n        WHEN \'£\' THEN \'GBP\'\n        WHEN \'eur\' THEN \'EUR\'\n        ELSE NULL\n    END AS "CurrencyIsoCode",\n    s.accountid AS "AccountId",\n    s.id AS "Legacy_Opportunity_ID__c",\n    NULL AS "CreatedDate",\n    NULL AS "LastModifiedDate",\n    0 AS "IsDeleted"\nFROM\n    {{ source(\'fixture_messy_data_v2_src\', \'opportunity\') }} AS s', 'normalize_opportunity.sql'])
