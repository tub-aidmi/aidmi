HEN POSITION(\'\'\',\'\'\' IN (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))) > 0\n                        AND POSITION(\'.\' IN (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))) > 0\n                        AND POSITION(\'.\' IN (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))) > POSITION(\'\'\',\'\'\' IN (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))) THEN\n                        REPLACE((TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\'))), \',\' , \'\')\n                    -- Only comma present: 123,45 (assume European decimal)\n                    WHEN POSITION(\'\'\',\'\'\' IN (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))) > 0 THEN\n                        REPLACE((TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\'))), \',\' , \'.\')\n                    ELSE\n                        -- Only dot present, or no separators: assume standard decimal\n                        (TRIM(REGEXP_REPLACE(REGEXP_REPLACE(LOWER(mo.auftragswert), \'(eur|chf|usd|gbp|€|\\$|euro|dollar)\\s*|\\s*(eur|chf|usd|gbp|€|\\$|euro|dollar)\', \'\', \'g\'), \'^\\s*-\\s*\', \'-\')))\n                END AS DOUBLE PRECISION)\n        END\n    AS "Amount",\n    UPPER(mo.waehrungscode) AS "CurrencyIsoCode",\n    mk.kundennummer AS "AccountId",\n    mo.opp_kennung AS "Legacy_Opportunity_ID__c",\n    NULL AS "CreatedDate",\n    NULL AS "LastModifiedDate",\n    0 AS "IsDeleted"\nFROM\n    {{ source(\'fixture_master_v2_src\', \'master_opportunities\') }} AS mo\nLEFT JOIN\n    {{ source(\'fixture_master_v2_src\', \'master_kunden\') }} AS mk\nON\n    mo.kunden_ref = mk.kundennummer;', '\n{{ config(materialized=\'table\') }}\n\nSELECT\n    opp.opp_kennung AS "Id",\n    COALESCE(opp.titel, \'Opportunity \' || opp.opp_kennung) AS "Name",\n    CASE\n        WHEN LOWER(TRIM(opp.vertriebsphase)) IN (\'won\', \'closed won\') THEN \'Closed Won\'\n        WHEN LOWER(TRIM(opp.vertriebsphase)) IN (\'lost\', \'verloren\') THEN \'Closed Lost\'\n        WHEN LOWER(TRIM(opp.vertriebsphase)) IN (\'qualifikation\', \'quali\', \'qualification\') THEN \'Qualification\'\n        WHEN LOWER(TRIM(opp.vertriebsphase)) = \'prospecting\' THEN \'Prospecting\'\n        WHEN LOWER(TRIM(opp.vertriebsphase)) = \'in prüfung\' THEN \'Negotiation/Review\'\n        WHEN LOWER(TRIM(opp.vertriebsphase)) = \'in kontakt\' THEN \'Prospecting\'\n        ELSE \'Prospecting\' -- Default for unmapped or NULL values, since StageName is NOT NULL\n    END AS "StageName",\n    TO_CHAR(\n        COALESCE(\n            CASE\n                WHEN opp.zieldatum ~ \'^\\d{4}-\\d{2}-\\d{2}$\' THEN TO_DATE(opp.zieldatum, \'YYYY-MM-DD\')\n                WHEN opp.zieldatum ~ \'^\\d{2}\\.\\d{2}\\.\\d{4}$\' THEN TO_DATE(opp.zieldatum, \'DD.MM.YYYY\')\n                WHEN opp.zieldatum ~ \'^\\d{1,2}/\\d{1,2}/\\d{4}$\' THEN TO_DATE(opp.zieldatum, \'MM/DD/YYYY\')\n                WHEN opp.zieldatum ~ \'^\\d{8}$\' THEN TO_DATE(opp.zieldatum, \'YYYYMMDD\')\n                ELSE NULL\n            END,\n            CURRENT_DATE\n        ), \'YYYY-MM-DD\'\n    ) AS "CloseDate",\n    CASE\n        WHEN opp.auftragswert IS NULL OR opp.auftragswert = \'None\' THEN NULL\n        ELSE\n            CAST(\n                REPLACE(\n                    REPLACE(\n                        REGEXP_REPLACE(opp.auftragswert, \'[^0-9.,-]\', \'\', \'g\'),\n                        \'.\', \'\'\n                    ),\n                    \',\', \'.\'\n                ) AS DOUBLE PRECISION\n            )\n    END AS "Amount",\n    UPPER(\n        CASE\n            WHEN LOWER(TRIM(opp.waehrungscode)) IN (\'$\', \'dollar\') THEN \'USD\'\n            WHEN LOWER(TRIM(opp.waehrungscode)) IN (\'€\', \'euro\') THEN \'EUR\'\n            WHEN LOWER(TRIM(opp.waehrungscode)) IN (\'chf\') THEN \'CHF\'\n            WHEN LOWER(TRIM(opp.waehrungscode)) IN (\'gbp\') THEN \'GBP\'\n            ELSE opp.waehrungscode\n        END\n    ) AS "CurrencyIsoCode",\n    mk.kundennummer AS "AccountId",\n    opp.opp_kennung AS "Legacy_Opportunity_ID__c",\n    NULL AS "CreatedDate",\n    NULL AS "LastModifiedDate",\n    0 AS "IsDeleted"\nFROM\n    {{ source(\'fixture_master_v2_src\', \'master_opportunities\') }} AS opp\nLEFT JOIN\n    {{ source(\'fixture_master_v2_src\', \'master_kunden\') }} AS mk\n    ON REPLACE(opp.kunden_ref, \'KD-\', \'CUST-\') = mk.kundennummer\n', '\n{{ config(materialized=\'table\') }}\n\nSELECT\n    mo.opp_kennung AS "Id",\n    COALESCE(mo.titel, \'Unknown Opportunity\') AS "Name",\n    CASE\n        WHEN LOWER(mo.vertriebsphase) IN (\'in kontakt\', \'prospecting\', \'prospect\') THEN \'Prospecting\'\n        WHEN LOWER(mo.vertriebsphase) IN (\'qualifikation\', \'quali\', \'qualification\') THEN \'Qualification\'\n        WHEN LOWER(mo.vertriebsphase) IN (\'in prüfung\') THEN \'Qualification\'\n        WHEN LOWER(mo.vertriebsphase) IN (\'won\', \'closed won\', \'abgeschlossen (gewonnen)\', \'gewonnen\') THEN \'Closed Won\'\n        WHEN LOWER(mo.vertriebsphase) IN (\'lost\', \'verloren\', \'closed lost\') THEN \'Closed Lost\'\n        ELSE \'Prospecting\' -- Default for unmapped phases, since StageName is NOT NULL\n    END AS "StageName",\n    COALESCE(\n        CASE\n            WHEN mo.zieldatum ~ \'^\\d{4}-\\d{2}-\\d{2}$\' THEN TO_CHAR(TO_DATE(mo.zieldatum, \'YYYY-MM-DD\'), \'YYYY-MM-DD\')\n            WHEN mo.zieldatum ~ \'^\\d{2}\\.\\d{2}\\.\\d{4}$\' THEN TO_CHAR(TO_DATE(mo.zieldatum, \'DD.MM.YYYY\'), \'YYYY-MM-DD\')\n            WHEN mo.zieldatum ~ \'^\\d{1,2}/\\d{1,2}/\\d{4}$\' THEN TO_CHAR(TO_DATE(mo.zieldatum, \'MM/DD/YYYY\'), \'YYYY-MM-DD\')\n            WHEN mo.zieldatum ~ \'^\\d{8}$\' THEN TO_CHAR(TO_DATE(mo.zieldatum, \'YYYYMMDD\'), \'YYYY-MM-DD\')\n            ELSE \'1900-01-01\' -- Default for unparseable dates, as CloseDate is NOT NULL\n        END,\n        \'1900-01-01\' -- Fallback for NULL zieldatum, as CloseDate is NOT NULL\n    ) AS "CloseDate",\n    CASE\n        WHEN mo.auftragswert IS NULL OR TRIM(mo.auftragswert) = \'\' THEN NULL\n        WHEN REGEXP_REPLACE(LOWER(mo.auftragswert), \'^(eur|chf|usd|gbp|€|\\$|£|euro|dollar)\\s*\', \'\', \'i\') ~ \'^-?\\d+(\\.\\d+)?$\'\n            THEN CAST(REGEXP_REPLACE(LOWER(mo.auftragswert), \'^(eur|chf|usd|gbp|€|\\$|£|euro|dollar)\\s*\', \'\', \'i\') AS DOUBLE PRECISION)\n        ELSE NULL\n    END AS "Amount",\n    CASE\n        WHEN LOWER(mo.waehrungscode) IN (\'chf\') THEN \'CHF\'\n        WHEN LOWER(mo.waehrungscode) IN (\'eur\', \'euro\', \'€\') THEN \'EUR\'\n        WHEN LOWER(mo.waehrungscode) IN (\'usd\', \'dollar\', \'$\') THEN \'USD\'\n        WHEN LOWER(mo.waehrungscode) IN (\'gbp\', \'£\') THEN \'GBP\'\n        ELSE NULL\n    END AS "CurrencyIsoCode",\n    mo.kunden_ref AS "AccountId",\n    mo.opp_kennung AS "Legacy_Opportunity_ID__c",\n    NULL AS "CreatedDate",\n    NULL AS "LastModifiedDate",\n    0 AS "IsDeleted"\nFROM\n    {{ source(\'fixture_master_v2_src\', \'master_opportunities\') }} AS mo\n'])
