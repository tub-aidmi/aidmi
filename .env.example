# Local development only — copy to `.env` (`just env`).
#
# Staging Postgres URL: set `AIDMI_STAGING_DB_URL` to override, otherwise the
# orchestrator CLI builds it from POSTGRES_* below (`postgresql://...`).
#
# aidmi-pipeline migrate reads `staging_db_url` from TOML configs, not this file;
# reuse the same credentials (or the composed URL) there when configuring migrations.

POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Optional override (leave unset to derive from POSTGRES_*)
# AIDMI_STAGING_DB_URL=

# --- LLM API keys (only what your strategy/grid YAML references via api_key_env) ---
# Set the keys for the providers you use; omit the rest.
# Models and base_url live in YAML (documentation/configuration.md). Ollama has no API key.

OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
LITELLM_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=